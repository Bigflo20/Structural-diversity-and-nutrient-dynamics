# Helper function for computing Shaoiro Wilk p value
safe_shapiro_p <- function(x) {
  x <- x[is.finite(x)]
  n <- length(x)
  if (n < 3 || n > 5000 || length(unique(x)) < 3) {
    return(NA_real_)
  }
  tryCatch(
    shapiro.test(x)$p.value,
    error = function(e) NA_real_)}

# Helper funciton for strictly positive values
shift_positive <- function(x, offset = 1e-6) {
  min_x <- min(x, na.rm = TRUE)
  if (is.na(min_x)) return(x)
  if (min_x <= 0) {x - min_x + offset} else {x}}

# Helper function for transforming variables
transform_candidates <- function(x) {
  x_pos <- shift_positive(x)
  list(
    raw = x,
    log = log(x_pos),
    sqrt = sqrt(x_pos))}


# Helper function for selecting best transformation for each variable
choose_best_transformation <- function(data, variable, alpha = 0.05) {
  x <- data[[variable]]
  raw_p <- safe_shapiro_p(x)
    # If raw variable is already approximately normal, keep raw
  if (!is.na(raw_p) && raw_p >= alpha) {
    return(data.frame(variable = variable, raw_shapiro_p = raw_p,
      selected_transformation = "raw", selected_shapiro_p = raw_p,
      stringsAsFactors = FALSE))}
  
    # If raw p < 0.05, test transformations
  candidates <- transform_candidates(x)
    trans_p <- purrr::map_dfr(names(candidates), function(tr) {
    data.frame(transformation = tr, shapiro_p = safe_shapiro_p(candidates[[tr]]),
      stringsAsFactors = FALSE) })
  
  best <- trans_p |>
    dplyr::filter(!is.na(shapiro_p)) |>
    dplyr::arrange(dplyr::desc(shapiro_p)) |>
    dplyr::slice(1)
  
  if (nrow(best) == 0) {
    return(data.frame(variable = variable, raw_shapiro_p = raw_p, selected_transformation = "raw",
      selected_shapiro_p = raw_p, stringsAsFactors = FALSE))}
  
  data.frame(
    variable = variable,
    raw_shapiro_p = raw_p,
    selected_transformation = best$transformation,
    selected_shapiro_p = best$shapiro_p,
    stringsAsFactors = FALSE)}

# Helper function to apply selected transformation
apply_selected_transformation <- function(x, transformation) {
  x_pos <- shift_positive(x)
  if (transformation == "raw") {return(x)}
  if (transformation == "log") {return(log(x_pos))}
  if (transformation == "sqrt") {return(sqrt(x_pos))}
  x}

