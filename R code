# 11. Cluster-bootstrapping of direct, indirect and total effects from main pSEM
#------------------------------------------------------------------------------#

# Important:
# - Bootstrap resampling is done at the plot_ID level.
# - Outliers are not removed.
# - Direct and indirect effects are calculated from standardized pSEM coefficients.
# - Indirect effects are products of coefficients along directed paths.
# - Relative-contribution calculations elsewhere remain significant-path-only.


##### Helper function to build the bootstrapping data
make_cluster_boot_data <- function(data, cluster_var = "plot_ID") {
  clusters <- unique(as.character(data[[cluster_var]]))
  sampled_clusters <- sample(clusters, size = length(clusters), replace = TRUE)
  
  boot_dat <- purrr::map2_dfr(sampled_clusters, seq_along(sampled_clusters), function(cl, i) {
    d <- data[data[[cluster_var]] == cl, , drop = FALSE]
    d[[cluster_var]] <- paste0(as.character(d[[cluster_var]]), "__boot", i)
    d})
  
  boot_dat[[cluster_var]] <- as.factor(boot_dat[[cluster_var]])
  if ("vegetation" %in% names(boot_dat)) boot_dat$vegetation <- as.factor(boot_dat$vegetation)
  boot_dat}



##### Helper function to extract path-specific effects from pSEM
path_specific_effects_from_psem <- function(sem_model, target,
                                            focal_sources = NULL,
                                            use_only_significant = FALSE,
                                            p_cutoff = 0.05,
                                            max_depth = 6) {
  
  cf <- get_coefs(sem_model) |>
    dplyr::filter(!predictor %in% c("(Intercept)", "~~"), !is.na(estimate))
  
  if (use_only_significant) {cf <- cf |>
      dplyr::filter(!is.na(p_value), p_value < p_cutoff)}
  
  edges <- cf |>
    dplyr::transmute(from = predictor, to = response, beta = estimate)
  
  paths <- all_paths_to_target(edges = edges, target = target, max_depth = max_depth)
  
  if (length(paths) == 0) {return(data.frame())  }
  
  path_tbl <- purrr::map_dfr(paths, function(p) {
    
    betas <- purrr::map2_dbl(p[-length(p)], p[-1],
      function(a, b) {
        edges |>
          dplyr::filter(from == a, to == b) |>
          dplyr::slice(1) |>
          dplyr::pull(beta)})
    
    data.frame(
      source = p[1],
      target = target,
      path = paste(p, collapse = " -> "),
      n_edges = length(betas),
      effect_type = dplyr::case_when(
        length(betas) == 1 ~ "direct",
        "agb" %in% p[-c(1, length(p))] ~ "agb_mediated_indirect",
        TRUE ~ "other_indirect"),
      path_effect = prod(betas),
      passes_through_agb = "agb" %in% p[-c(1, length(p))],
      stringsAsFactors = FALSE)})
  
  if (!is.null(focal_sources)) {path_tbl <- path_tbl |>
      dplyr::filter(source %in% focal_sources)}
  path_tbl}



# Helper function to fix naming so that bootstrap replicates can be combined 
# even if one path is absent in a failed/singular replicate

vectorize_path_effects_for_boot <- function(path_tbl, path_names) {
  
  out <- setNames(rep(NA_real_, length(path_names)), path_names)
  
  if (nrow(path_tbl) == 0) return(out)
  
  for (pth in path_names) {row <- path_tbl |>
      dplyr::filter(path == pth)
    
    if (nrow(row) == 1) {out[pth] <- row$path_effect}}
  out}


# Helper function to bootstrap path-specific indirect effects for one pSEM
bootstrap_psem_path_specific_one_model <- function(data, index_var, response, clay, cwm,
                                                   focal_sources = NULL,
                                                   n_boot = 1000,
                                                   seed = 123,
                                                   use_only_significant = FALSE,
                                                   p_cutoff = 0.05,
                                                   max_depth = 6) {
  
  if (is.null(focal_sources)) {
    focal_sources <- c(index_var, "agb", "ai", "hmod", clay, cwm, "fdis", "sesmpd")}
  
  focal_sources <- unique(focal_sources)
  
  set.seed(seed)
  
  # Original pSEM
  original_sem <- build_main_psem(data = data, index_var = index_var, response = response, clay = clay, cwm = cwm)
  
  original_paths <- path_specific_effects_from_psem(
    sem_model = original_sem,
    target = response,
    focal_sources = focal_sources,
    use_only_significant = use_only_significant,
    p_cutoff = p_cutoff,
    max_depth = max_depth)
  
  if (nrow(original_paths) == 0) {
    warning("No paths found in original model for response: ", response)
    return(NULL)}
  
  path_names <- original_paths$path
  
  original_vector <- vectorize_path_effects_for_boot(
    path_tbl = original_paths,
    path_names = path_names)
  
  boot_mat <- matrix(NA_real_, nrow = n_boot, ncol = length(original_vector))
  colnames(boot_mat) <- names(original_vector)
  
  boot_status <- data.frame(iteration = seq_len(n_boot), success = FALSE, error = NA_character_  )
  for (b in seq_len(n_boot)) {
  boot_dat <- make_cluster_boot_data(data = data, cluster_var = "plot_ID"    )
    
    res <- tryCatch({
        boot_sem <- build_main_psem(data = boot_dat, index_var = index_var,
        response = response, clay = clay, cwm = cwm)
      
      boot_paths <- path_specific_effects_from_psem(
        sem_model = boot_sem,
        target = response,
        focal_sources = focal_sources,
        use_only_significant = use_only_significant,
        p_cutoff = p_cutoff,
        max_depth = max_depth)
      
      vectorize_path_effects_for_boot(path_tbl = boot_paths, path_names = path_names)
      
    }, error = function(e) e)
    
    if (inherits(res, "error")) {
      boot_status$success[b] <- FALSE
      boot_status$error[b] <- conditionMessage(res)
    } else {
      boot_mat[b, ] <- res
      boot_status$success[b] <- TRUE}}
  
  boot_summary <- summarise_boot_path_effects(
    original_paths = original_paths,
    boot_matrix = boot_mat,
    conf = 0.95) |>
    dplyr::mutate(
      index = index_var,
      response = response,
      clay = clay,
      cwm = cwm,
      n_boot_requested = n_boot,
      n_model_successful = sum(boot_status$success))
  
  list(original_paths = original_paths, bootstrap_summary = boot_summary,
    bootstrap_replicates = as.data.frame(boot_mat), bootstrap_status = boot_status)
}


# Summarise path-specific bootstrap effects
summarise_boot_path_effects <- function(original_paths, boot_matrix, conf = 0.95) {
  alpha <- 1 - conf
  purrr::map_dfr(colnames(boot_matrix), function(path_name) {
    
    vals <- boot_matrix[, path_name]
    vals <- vals[is.finite(vals)]
    
    orig <- original_paths |>
      dplyr::filter(path == path_name) |>
      dplyr::slice(1)
    
    data.frame(
      source = orig$source,
      target = orig$target,
      path = path_name,
      n_edges = orig$n_edges,
      effect_type = orig$effect_type,
      passes_through_agb = orig$passes_through_agb,
      original_estimate = orig$path_effect,
      bootstrap_mean = if (length(vals) > 0) mean(vals, na.rm = TRUE) else NA_real_,
      bootstrap_sd = if (length(vals) > 1) sd(vals, na.rm = TRUE) else NA_real_,
      ci_lower = if (length(vals) > 10) {
        stats::quantile(vals, probs = alpha / 2, na.rm = TRUE)
      } else {
        NA_real_},
      ci_upper = if (length(vals) > 10) {
        stats::quantile(vals, probs = 1 - alpha / 2, na.rm = TRUE)
      } else {
        NA_real_},
      n_successful = length(vals),
      stringsAsFactors = FALSE)})
}


# Run path-specific bootstrap across all depths
run_psem_path_specific_bootstrap_all_depths <- function(data = data_flo,
                                                        config = model_config,
                                                        index_var = "vci_sum",
                                                        n_boot = 1000,
                                                        seed = 123,
                                                        max_depth = 6,
                                                        out_prefix = "pSEM_path_specific") {
  
  boot_summaries <- list()
  boot_originals <- list()
  boot_statuses <- list()
  
  for (i in seq_len(nrow(config))) {
    
    cfg <- config[i, ]
    
    model_id <- paste(cfg$family, cfg$depth_label, index_var, "path_specific_bootstrap", sep = "_") |>
      stringr::str_replace_all("[^A-Za-z0-9]+", "_")
    
    message("Bootstrapping path-specific pSEM effects: ", model_id)
    
    focal_sources <- unique(c(index_var, "agb", "ai", "hmod", cfg$clay, cfg$cwm, "fdis", "sesmpd"))
    
    out <- bootstrap_psem_path_specific_one_model(
      data = data,
      index_var = index_var,
      response = cfg$response,
      clay = cfg$clay,
      cwm = cfg$cwm,
      focal_sources = focal_sources,
      n_boot = n_boot,
      seed = seed + i,
      use_only_significant = FALSE,
      max_depth = max_depth)
    
    if (is.null(out)) next
    
    boot_summaries[[model_id]] <- out$bootstrap_summary |>
      dplyr::mutate(
        model_id = model_id,
        family = cfg$family,
        depth_label = cfg$depth_label)
    
    boot_originals[[model_id]] <- out$original_paths |>
      dplyr::mutate(
        model_id = model_id,
        family = cfg$family,
        depth_label = cfg$depth_label,
        index = index_var,
        response_variable = cfg$response)
    
    boot_statuses[[model_id]] <- out$bootstrap_status |>
      dplyr::mutate(
        model_id = model_id,
        family = cfg$family,
        depth_label = cfg$depth_label,
        response = cfg$response,
        index = index_var)
    
    write.csv(out$bootstrap_replicates, paste0(out_prefix, "_replicates_", model_id, ".csv"), row.names = FALSE )
  }
  
  summary_tbl <- dplyr::bind_rows(boot_summaries)
  original_tbl <- dplyr::bind_rows(boot_originals)
  status_tbl <- dplyr::bind_rows(boot_statuses)
  
  summary_tbl <- summary_tbl |>
    dplyr::mutate(supported = !is.na(ci_lower) & !is.na(ci_upper) & ci_lower * ci_upper > 0,
      ci_95 = paste0("[", round(ci_lower, 3), ", ", round(ci_upper, 3), "]"))
  
  write.csv( summary_tbl, paste0(out_prefix, "_bootstrap_path_specific_summary_", index_var, ".csv"), row.names = FALSE)
  write.csv( original_tbl, paste0(out_prefix, "_original_path_specific_effects_", index_var, ".csv"), row.names = FALSE)
  write.csv(status_tbl, paste0(out_prefix, "_bootstrap_status_", index_var, ".csv"), row.names = FALSE)
  
  list(summary = summary_tbl, original = original_tbl, status = status_tbl)}


