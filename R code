# 8. Model selection with VIF filtering and model averaging
#------------------------------------------------------------------------------#

## Helper function for running "dredge"
run_dredge_with_vif_filter <- function(response, predictors, data, random = "~1|vegetation/plot_ID",
                                       vif_threshold = 5, delta_threshold = 2) {
  form <- as.formula(paste(response, "~", paste(predictors, collapse = " + ")))
  global_model <- nlme::lme(form, random = as.formula(random), data = data, method = "ML")
  dd <- MuMIn::dredge(global_model, beta = "sd", rank = "AICc", trace = FALSE, REML = FALSE)
  mods <- MuMIn::get.models(dd, subset = TRUE)
  ok <- purrr::map_lgl(mods, vif_ok_lme, threshold = vif_threshold)
  dd$vif_ok <- ok
  dd$delta_AICc <- dd$delta
  viable <- dd |> as.data.frame() |> tibble::rownames_to_column("model_id") |> filter(vif_ok)
  write.csv(viable, paste0("dredge_VIF_filtered_", response, ".csv"), row.names = FALSE)

  top_ids <- as.numeric(viable$model_id[viable$delta_AICc <= delta_threshold])
  if (length(top_ids) == 0) top_ids <- as.numeric(viable$model_id[1])
  top_models <- mods[top_ids]
  avg_model <- tryCatch(MuMIn::model.avg(top_models), error = function(e) NULL)

  list(global_model = global_model, dredge_table = dd, viable_table = viable,
       top_models = top_models, model_average = avg_model)}


## Helper function for extracting VIF from top models
extract_vif_from_top_models <- function(top_mods,
    out_file_full = "VIF_top_models_used_for_model_averaging.csv",
    out_file_summary = "VIF_summary_top_models_used_for_model_averaging.csv") {
    # Full VIF table for each top model
    vif_tbl <- purrr::imap_dfr(top_mods, function(m, i) {
    component_response <- tryCatch(all.vars(stats::formula(m))[1], error = function(e) NA_character_)
    model_formula <- tryCatch(paste(deparse(stats::formula(m)), collapse = " "), error = function(e) NA_character_)
    safe_vif_lme(m) |> dplyr::mutate(top_model = i, component_response = component_response, model_formula = model_formula)})
  
    # Summary VIF table across top models
    vif_summary <- vif_tbl |>
    dplyr::filter(!is.na(VIF)) |>
    dplyr::group_by(term) |>
    dplyr::summarise(
      min_VIF = min(VIF, na.rm = TRUE),
      mean_VIF = mean(VIF, na.rm = TRUE),
      max_VIF = max(VIF, na.rm = TRUE),
      n_models = dplyr::n_distinct(top_model),
      .groups = "drop") |>
    dplyr::arrange(dplyr::desc(max_VIF))
  
  # Export both tables
  write.csv(vif_tbl, out_file_full, row.names = FALSE)
  write.csv(vif_summary, out_file_summary, row.names = FALSE)
  
  # Return both tables
  list(full = vif_tbl, summary = vif_summary)}


