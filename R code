                                              out_file = "feedback_soil_AGB_VCI_forest.tiff") {
  
  plot_df <- feedback_path_results$summary |>
    dplyr::mutate(expected_path = paste(nutrient_var, "agb", index_var, sep = " -> ")) |>
    dplyr::filter(effect_type == "agb_mediated_indirect", n_edges == 2, target == index_var,
      source == nutrient_var, path == expected_path) |>
    dplyr::distinct(family, depth_label, nutrient_var, source, target, path, .keep_all = TRUE) |>
    dplyr::mutate(supported = !is.na(ci_lower) & !is.na(ci_upper) & ci_lower * ci_upper > 0,
      label = paste(family, depth_label, sep = " | "),
      label = factor(
        label, levels = c(
          "SOC | 0-60 cm",
          "SOC | 0-20 cm",
          "SOC | 20-40 cm",
          "SOC | 40-60 cm",
          "STN | 0-60 cm",
          "STN | 0-20 cm",
          "STN | 20-40 cm",
          "STN | 40-60 cm",
          "SCN | 0-60 cm",
          "SCN | 0-20 cm",
          "SCN | 20-40 cm",
          "SCN | 40-60 cm"
        ))) |>
    dplyr::filter(!is.na(label))
  
  # Diagnostic check: should be 12 rows maximum
  print(plot_df |>
      dplyr::select(family, depth_label, nutrient_var, source, target, path, n_edges, effect_type))
  
  if (nrow(plot_df) == 0) {warning("No exact soil C/N -> AGB -> VCI paths found.")
    return(list(plot_data = plot_df, plot = NULL))}
  
  p <- ggplot2::ggplot(plot_df,
    ggplot2::aes(x = original_estimate, y = label, xmin = ci_lower, xmax = ci_upper, shape = supported)) +
    ggplot2::geom_vline(xintercept = 0, linetype = "dashed", linewidth = 0.5) +
    ggplot2::geom_errorbar(orientation = "y", width = 0.2, linewidth = 0.6) +
    ggplot2::geom_point(size = 3) +
    ggplot2::scale_y_discrete(limits = rev(levels(plot_df$label))) +
    ggplot2::labs(x = "Bootstrapped indirect effect", y = NULL,
      shape = "Supported", title = " SOC, STN, SCN -> AGB -> VCI ") +
    ggplot2::theme_classic(base_size = 14) +
    ggplot2::theme(
      axis.title.x = ggplot2::element_text(face = "bold", size = 15),
      axis.text.x = ggplot2::element_text(size = 12),
      axis.text.y = ggplot2::element_text(face = "bold", size = 13),
      plot.title = ggplot2::element_text(face = "bold", size = 15, hjust = 0.5),
      legend.title = ggplot2::element_text(face = "bold", size = 13),
      legend.text = ggplot2::element_text(face = "bold", size = 12))
  
  ggplot2::ggsave(filename = out_file, plot = p, width = 5.5, height = 6,
    units = "in", dpi = 600, compression = "lzw")
  
  list(plot_data = plot_df, plot = p)
}



##### One wrapper: pSEM, bootstrap + supported table + forest plot
run_feedback_path_specific_bootstrap_summary_and_plot <- function(data = data_flo,
                                                                  config = model_config, index_var = "vci_sum",
                                                                  n_boot = 1000, seed = 123,
                                                                  max_depth = 6, out_prefix = "feedback_path_specific") {
  # 1. Run path-specific bootstrap
  feedback_path_results <- run_feedback_path_specific_bootstrap_all(
    data = data, config = config, index_var = index_var, n_boot = n_boot, seed = seed,
    max_depth = max_depth, out_prefix = out_prefix)
  
  # 2. Extract supported path-specific effects
  supported <- extract_supported_feedback_path_specific_effects(
    feedback_path_results = feedback_path_results,
    out_file_all = paste0(out_prefix, "_supported_path_specific_effects_", index_var, ".csv"),
    out_file_clean = paste0(out_prefix, "_supported_path_specific_effects_clean_", index_var, ".csv"))
  
  # 3. Extract specific soil C/N -> AGB -> VCI summary
  soil_agb_vci_summary <- feedback_path_results$summary |>
    dplyr::filter(
      effect_type == "agb_mediated_indirect", path == paste(source, "agb", index_var, sep = " -> ")) |>
    dplyr::mutate(supported = !is.na(ci_lower) & !is.na(ci_upper) & ci_lower * ci_upper > 0,
      ci_95 = paste0("[", round(ci_lower, 3), ", ", round(ci_upper, 3), "]"), 
      estimate = round(original_estimate, 3)) |>
    dplyr::select(family, depth_label, nutrient_var, index, path, estimate, ci_95,
      supported, n_successful, n_boot_requested, n_model_successful)
  write.csv(soil_agb_vci_summary, paste0(out_prefix, "_soil_AGB_VCI_mediation_summary_", index_var, ".csv"), row.names = FALSE)
  
  # 4. Forest plot
  forest <- plot_feedback_soil_agb_vci_forest(feedback_path_results = feedback_path_results, index_var = index_var,
    out_file = paste0(out_prefix, "_soil_AGB_VCI_forest_", index_var, ".tiff"))
  list(feedback_path_results = feedback_path_results, supported_effects = supported, soil_agb_vci_summary = soil_agb_vci_summary,
    forest_plot = forest$plot, forest_plot_data = forest$plot_data)}



