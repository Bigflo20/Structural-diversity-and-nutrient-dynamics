###### Helper function for building feedback pSEM
build_feedback_psem <- function(data, nutrient_var, index_var, clay, cwm) {
  
  piecewiseSEM::psem(
    
    # Soil nutrient response to environmental and human drivers
    fit_lme( paste0(nutrient_var, " ~ ai + ", clay, " + hmod"), data = data),
    # AGB response to environment + nutrient feedback
    fit_lme(paste0("agb ~ ai + ", clay, " + hmod + ", nutrient_var), data = data),
    # Functional diversity response
    fit_lme(paste0("fdis ~ ai + ", clay, " + hmod + ", nutrient_var, " + agb"), data = data),
    # CWM trait response
    fit_lme(paste0(cwm, " ~ ai + ", clay, " + hmod + ", nutrient_var, " + agb"), data = data),
    
    # Phylogenetic structure response
    fit_lme(paste0("sesmpd ~ ai + ", clay, " + hmod + ", nutrient_var, " + agb"), data = data),
    
    # Vegetation complexity response
    fit_lme(paste0(index_var, " ~ ai + ", clay, " + hmod + ", nutrient_var, " + agb + fdis + ", cwm, " + sesmpd"), data = data))
}




##### Helper functiom to run all feedback pSEMs and export diagnostics/results
run_all_feedback_psems <- function(indices = sensitivity_indices,
                                   data = data_flo,
                                   config = model_config,
                                   p_cutoff = 0.05,
                                   use_only_significant = TRUE,
                                   out_prefix = "feedback") {
  
  all_results <- list()
  all_rc <- list()
  all_fit <- list()
  all_coef <- list()
  all_vif <- list()
  all_diag <- list()
  all_r2 <- list()
  
  for (idx in indices) {
    for (i in seq_len(nrow(config))) {
      
      cfg <- config[i, ]
      
      model_id <- paste(cfg$family, cfg$depth_label, cfg$response, 
        "to", idx, "feedback", sep = "_") |>
        stringr::str_replace_all("[^A-Za-z0-9]+", "_")
      
      message("Fitting feedback pSEM: ", model_id)
      
      # Fit sem
        sem <- build_feedback_psem(data = data, nutrient_var = cfg$response, index_var = idx,
        clay = cfg$clay, cwm = cfg$cwm)
      sm <- summary(sem)
      cf <- get_coefs(sem)
      
      # Relative contributions to VCI/index response
      rc <- relative_contribution_from_psem( sem, target = idx, p_cutoff = p_cutoff,
        use_only_significant = use_only_significant)
      
      if (is.list(rc) && !is.null(rc$total_effects) && nrow(rc$total_effects) > 0) {
        
        all_rc[[model_id]] <- rc$total_effects |>
          dplyr::mutate(
            family = cfg$family, depth_label = cfg$depth_label, nutrient_var = cfg$response,
            response = idx, index = idx, PredictorGroup = label_predictor_group(source, index_label = "VCI")) |>
          dplyr::group_by(family, depth_label, nutrient_var, response, index, PredictorGroup) |>
          dplyr::summarise(total_effect = sum(total_effect, na.rm = TRUE),
            relative_contribution = sum(relative_contribution, na.rm = TRUE), .groups = "drop")
        
        write.csv(rc$paths, paste0(out_prefix, "_paths_", model_id, ".csv"), row.names = FALSE)}
      
      # Extract component lme models from pSEM object
      mods <- if (!is.null(sem$modelList)) {
      sem$modelList
      } else {
        sem}
      mods <- mods[purrr::map_lgl(mods, ~ inherits(.x, "lme"))]
      
      # VIF for each component lme model
      vif_tbl <- purrr::imap_dfr(mods, function(m, j) {component_response <- tryCatch(
          all.vars(stats::formula(m))[1], error = function(e) NA_character_ )
        
        component_formula <- tryCatch(paste(deparse(stats::formula(m)), collapse = " "), error = function(e) NA_character_)
        
        safe_vif_lme(m) |>
          dplyr::mutate(
            component_model = as.character(j),
            component_response = component_response,
            component_formula = component_formula,
            model_id = model_id,
            family = cfg$family,
            depth_label = cfg$depth_label,
            nutrient_var = cfg$response,
            response = idx,
            index = idx)})
      
      if (nrow(vif_tbl) == 0) {
        warning("No VIF values extracted for feedback model: ", model_id)
      }
      
      # Residual diagnostics for each component lme model
      diag_tbl <- purrr::imap_dfr(mods, function(m, j) {component_response <- tryCatch(
          all.vars(stats::formula(m))[1], error = function(e) NA_character_)
      component_formula <- tryCatch(paste(deparse(stats::formula(m)), collapse = " "),
          error = function(e) NA_character_)
        
        dg <- diagnose_lme( model = m, model_name = paste0(model_id, "_component_", j))
        
        data.frame(
          model_id = model_id,
          family = cfg$family,
          depth_label = cfg$depth_label,
          nutrient_var = cfg$response,
          response = idx,
          index = idx,
          component_model = as.character(j),
          component_response = component_response,
          component_formula = component_formula,
          shapiro_residual_p = dg$shapiro_residual_p,
          n_residual_outliers_abs_z_gt_3 = nrow(dg$residual_outliers),
          stringsAsFactors = FALSE)})
      
      if (nrow(diag_tbl) == 0) {
        warning("No residual diagnostics extracted for feedback model: ", model_id)
      }
      
      # Marginal and conditional R2 for each component lme model
      r2_tbl <- purrr::imap_dfr(mods, function(m, j) {
        component_response <- tryCatch(all.vars(stats::formula(m))[1], error = function(e) NA_character_)
        component_formula <- tryCatch( paste(deparse(stats::formula(m)), collapse = " "), error = function(e) NA_character_ )
        
        r2_out <- tryCatch(piecewiseSEM::rsquared(m), error = function(e) NULL)
        
        if (is.null(r2_out)) {
          return(data.frame(
            model_id = model_id,
            family = cfg$family,
            depth_label = cfg$depth_label,
            nutrient_var = cfg$response,
            response = idx,
            index = idx,
            component_model = as.character(j),
            component_response = component_response,
            component_formula = component_formula,
            marginal_R2 = NA_real_,
            conditional_R2 = NA_real_,
            stringsAsFactors = FALSE))}
        
        data.frame(
          model_id = model_id,
          family = cfg$family,
          depth_label = cfg$depth_label,
          nutrient_var = cfg$response,
          response = idx,
          index = idx,
          component_model = as.character(j),
          component_response = component_response,
          component_formula = component_formula,
          marginal_R2 = r2_out$Marginal,
          conditional_R2 = r2_out$Conditional,
          stringsAsFactors = FALSE)})
      
      if (nrow(r2_tbl) == 0) {
        warning("No R2 values extracted for feedback model: ", model_id)}
      
      # Store outputs
      all_results[[model_id]] <- sem
      
      all_fit[[model_id]] <- data.frame(
        model_id = model_id,
        family = cfg$family,
        depth_label = cfg$depth_label,
        nutrient_var = cfg$response,
        response = idx,
        index = idx,
        Fisher_C = tryCatch(sm$Cstat$Fisher.C, error = function(e) NA_real_),
        df = tryCatch(sm$Cstat$df, error = function(e) NA_real_),
        C_p_value = tryCatch(sm$Cstat$P.Value, error = function(e) NA_real_),
        AIC = tryCatch(AIC(sem), error = function(e) NA_real_),
        stringsAsFactors = FALSE)
      
      all_coef[[model_id]] <- cf |>
        dplyr::mutate(
          model_id = model_id,
          family = cfg$family,
          depth_label = cfg$depth_label,
          nutrient_var = cfg$response,
          response_variable = idx,
          index = idx)
      
      all_vif[[model_id]] <- vif_tbl
      all_diag[[model_id]] <- diag_tbl
      all_r2[[model_id]] <- r2_tbl} }
  
  # Bind outputs
  rc_tbl <- dplyr::bind_rows(all_rc)
  fit_tbl <- dplyr::bind_rows(all_fit)
  coef_tbl <- dplyr::bind_rows(all_coef)
  vif_tbl <- dplyr::bind_rows(all_vif)
  diag_tbl <- dplyr::bind_rows(all_diag)
  r2_tbl <- dplyr::bind_rows(all_r2)
  
  # Export outputs
  write.csv(rc_tbl, paste0(out_prefix, "_relative_contributions_all_indices.csv"), row.names = FALSE)
  write.csv(fit_tbl, paste0(out_prefix, "_pSEM_fit_all_indices.csv"), row.names = FALSE)
  write.csv(coef_tbl, paste0(out_prefix, "_pSEM_coefficients_all_indices.csv"), row.names = FALSE)
  write.csv(vif_tbl, paste0(out_prefix, "_pSEM_VIF_all_indices.csv"), row.names = FALSE )
  write.csv(diag_tbl, paste0(out_prefix, "_pSEM_lme_diagnostics_all_indices.csv"), row.names = FALSE)
  write.csv(r2_tbl, paste0(out_prefix, "_pSEM_lme_R2_all_indices.csv"), row.names = FALSE)
  
  list(models = all_results, relative_contributions = rc_tbl, fit = fit_tbl,  coefficients = coef_tbl,
    vif = vif_tbl, diagnostics = diag_tbl, r2 = r2_tbl)
}



