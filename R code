  all_fit <- list()  # store model fit statistics
  all_coef <- list() # store path coefficients
  all_vif <- list()  # store vif output
  all_diag <- list() # store dignostic output
  all_r2 <- list()   # store marginal and conditional R2
  
  for (idx in indices) {
    for (i in seq_len(nrow(model_config))) {cfg <- model_config[i, ]
      
      model_id <- paste(cfg$family, cfg$depth_label, idx, sep = "_") |>
        stringr::str_replace_all("[^A-Za-z0-9]+", "_")
      
      message("Fitting: ", model_id)
      
      sem <- build_main_psem(data, idx, cfg$response, cfg$clay, cfg$cwm)
      sm <- summary(sem)
      cf <- get_coefs(sem)
      
      rc <- relative_contribution_from_psem(sem, target = cfg$response, 
            p_cutoff = p_cutoff, use_only_significant = use_only_significant)
      
      if (is.list(rc) && !is.null(rc$total_effects) && nrow(rc$total_effects) > 0) {
        all_rc[[model_id]] <- rc$total_effects |>
          dplyr::mutate(family = cfg$family, depth_label = cfg$depth_label,
            response = cfg$response, index = idx,
            PredictorGroup = label_predictor_group(source, index_label = "VCI")) |>
          dplyr::group_by(family, depth_label, response, index, PredictorGroup) |>
          dplyr::summarise(total_effect = sum(total_effect, na.rm = TRUE),
            relative_contribution = sum(relative_contribution, na.rm = TRUE), .groups = "drop")
        
        write.csv(rc$paths, paste0("paths_", model_id, ".csv"), row.names = FALSE )}
      
      # ------------------------------------------------------------
      # Extract component lme models from pSEM object
      # ------------------------------------------------------------
      mods <- if (!is.null(sem$modelList)) {
        sem$modelList} else {sem}
            mods <- mods[purrr::map_lgl(mods, ~ inherits(.x, "lme"))]
      
      # ------------------------------------------------------------
      # VIF for each component lme model
      # ------------------------------------------------------------
      vif_tbl <- purrr::imap_dfr(mods, function(m, j) {
        component_response <- tryCatch(all.vars(stats::formula(m))[1], error = function(e) NA_character_)
        component_formula <- tryCatch(paste(deparse(stats::formula(m)), collapse = " "), error = function(e) NA_character_)
        
        safe_vif_lme(m) |>
        dplyr::mutate(component_model = as.character(j), component_response = component_response,
        component_formula = component_formula, model_id = model_id, family = cfg$family,
        depth_label = cfg$depth_label,
        response = cfg$response, index = idx)})
      if (nrow(vif_tbl) == 0) {warning("No VIF values extracted for model: ", model_id)}
      
      # ------------------------------------------------------------
      # Residual diagnostics for each component lme model
      # ------------------------------------------------------------
      diag_tbl <- purrr::imap_dfr(mods, function(m, j) {
        
        component_response <- tryCatch(all.vars(stats::formula(m))[1], error = function(e) NA_character_)
        
        component_formula <- tryCatch(paste(deparse(stats::formula(m)), collapse = " "),
        error = function(e) NA_character_)
        
        dg <- diagnose_lme(model = m, model_name = paste0(model_id, "_component_", j))
        
        data.frame(
          model_id = model_id,
          family = cfg$family,
          depth_label = cfg$depth_label,
          response = cfg$response,
          index = idx,
          component_model = as.character(j),
          component_response = component_response,
          component_formula = component_formula,
          shapiro_residual_p = dg$shapiro_residual_p,
          n_residual_outliers_abs_z_gt_3 = nrow(dg$residual_outliers),
          stringsAsFactors = FALSE)})
      
      if (nrow(diag_tbl) == 0) {
        warning("No residual diagnostics extracted for model: ", model_id)}
      
      # ------------------------------------------------------------
      # Marginal and conditional R2 for each component lme model
      # ------------------------------------------------------------
      r2_tbl <- purrr::imap_dfr(mods, function(m, j) {
        component_response <- tryCatch(all.vars(stats::formula(m))[1], error = function(e) NA_character_)
        component_formula <- tryCatch(paste(deparse(stats::formula(m)), collapse = " "), error = function(e) NA_character_)
        
        r2_out <- tryCatch(piecewiseSEM::rsquared(m), error = function(e) NULL)
        
        if (is.null(r2_out)) {
          return(data.frame(
            model_id = model_id,
            family = cfg$family,
            depth_label = cfg$depth_label,
            response = cfg$response,
            index = idx,
            component_model = as.character(j),
            component_response = component_response,
            component_formula = component_formula,
            marginal_R2 = NA_real_,
            conditional_R2 = NA_real_,
            stringsAsFactors = FALSE))}
        
        data.frame(
          model_id = model_id,
          family = cfg$family,
          depth_label = cfg$depth_label,
          response = cfg$response,
          index = idx,
          component_model = as.character(j),
          component_response = component_response,
          component_formula = component_formula,
          marginal_R2 = r2_out$Marginal,
          conditional_R2 = r2_out$Conditional,
          stringsAsFactors = FALSE)})
      
      if (nrow(r2_tbl) == 0) {
        warning("No R2 values extracted for model: ", model_id)}
      
      # ------------------------------------------------------------
      # Store outputs
      # ------------------------------------------------------------
      all_results[[model_id]] <- sem
      
      all_fit[[model_id]] <- data.frame(
        model_id = model_id,
        family = cfg$family,
        depth_label = cfg$depth_label,
        response = cfg$response,
        index = idx,
        Fisher_C = sm$Cstat$Fisher.C,
        df = sm$Cstat$df,
        C_p_value = sm$Cstat$P.Value,
        AIC = tryCatch(AIC(sem), error = function(e) NA_real_))
      
      all_coef[[model_id]] <- cf |>
        dplyr::mutate(
          model_id = model_id,
          family = cfg$family,
          depth_label = cfg$depth_label,
          response_variable = cfg$response,
          index = idx)
      
      all_vif[[model_id]] <- vif_tbl
      all_diag[[model_id]] <- diag_tbl
      all_r2[[model_id]] <- r2_tbl} }
  
  rc_tbl <- dplyr::bind_rows(all_rc)
  fit_tbl <- dplyr::bind_rows(all_fit)
  coef_tbl <- dplyr::bind_rows(all_coef)
  vif_tbl <- dplyr::bind_rows(all_vif)
  diag_tbl <- dplyr::bind_rows(all_diag)
  r2_tbl <- dplyr::bind_rows(all_r2)
  
  write.csv(rc_tbl, "relative_contributions_all_indices.csv", row.names = FALSE)
  write.csv(fit_tbl, "pSEM_fit_all_indices.csv", row.names = FALSE)
  write.csv(coef_tbl, "pSEM_coefficients_all_indices.csv", row.names = FALSE)
  write.csv(vif_tbl, "pSEM_VIF_all_indices.csv", row.names = FALSE)
  write.csv(diag_tbl, "pSEM_lme_diagnostics_all_indices.csv", row.names = FALSE)
  write.csv(r2_tbl, "pSEM_lme_R2_all_indices.csv", row.names = FALSE)
  
  list(models = all_results, relative_contributions = rc_tbl,     fit = fit_tbl,
    coefficients = coef_tbl, vif = vif_tbl, diagnostics = diag_tbl, r2 = r2_tbl)}


