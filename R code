##### Helper function for running all bivariate models
run_all_bivariate_models <- function(data = data_flo,
                                     config = model_config,
                                     indices = sensitivity_indices,
                                     out_file = "bivariate_results_all_families.csv") {
    all_results <- purrr::pmap_dfr(
    config,
    function(family, depth_label, response, clay, cwm, ...) {
      
      predictors <- c("agb", "sesmpd", cwm, "fdis", indices, clay, "ai", "hmod")
      
      predictors <- unique(predictors)
      
      purrr::map_dfr(
        predictors, ~ extract_bivariate_slope(
          response = response,
          predictor = .x,
          family = family,
          depth_label = depth_label,
          clay = clay,
          cwm = cwm,
          data = data))}) |>
    dplyr::mutate(
      PredictorGroup = label_bivariate_predictor(predictor),
      PredictorGroup = factor(
        PredictorGroup, levels = bivariate_predictor_levels),
      depth_label = factor(
        depth_label,
        levels = c("0-60 cm", "0-20 cm", "20-40 cm", "40-60 cm")),
      family = factor(
        family, levels = c("SOC", "STN", "SCN")),
      Significance = dplyr::case_when(
        model_failed ~ "Model failed",
        p_value < 0.05 & slope > 0 ~ "Significant & Positive",
        p_value < 0.05 & slope < 0 ~ "Significant & Negative",
        TRUE ~ "Non-significant"),
      Border_Color = dplyr::case_when(
        model_failed ~ "grey",
        slope > 0 ~ "blue",
        slope < 0 ~ "red",
        TRUE ~ "grey"))
  
  write.csv(all_results, out_file, row.names = FALSE)
  all_results
}


##### Helper function for plotting bivariate slopes for one family
plot_bivariate_family <- function(results,
                                  family_name,
                                  plot_title,
                                  out_file,
                                  width = 7.5,
                                  height = 7.5,
                                  show_legend = TRUE) {
  
  plot_df <- results |>
    dplyr::filter(family == family_name) |>
    dplyr::filter(!is.na(PredictorGroup)) |>
    droplevels()
  
  p <- ggplot2::ggplot(plot_df, ggplot2::aes(x = depth_label, y = PredictorGroup)) +
    ggplot2::geom_point(
      ggplot2::aes(size = abs(slope), fill = Significance, color = Border_Color),
      shape = 21, stroke = 0.5, show.legend = c(color = FALSE)) +
    ggplot2::scale_fill_manual(
      values = c(
        "Significant & Positive" = "blue",
        "Significant & Negative" = "red",
        "Non-significant" = "white",
        "Model failed" = "grey80"),
      drop = TRUE) +
    ggplot2::scale_color_manual(
      values = c(
        "blue" = "blue",
        "red" = "red",
        "grey" = "grey"),
      drop = TRUE) +
    ggplot2::scale_size_continuous(range = c(3, 8), name = "Abs(Slope)") +
    ggplot2::scale_y_discrete(
      labels = function(x) parse(text = bivariate_predictor_labels[x])) +
    ggplot2::labs(title = plot_title, x = "Layer", y = "", fill = "Significance & sign") +
    ggplot2::theme_bw() +
    ggplot2::theme(
      axis.text.x = ggplot2::element_text(angle = 45, hjust = 1, face = "bold", size = 12),
      axis.text.y = ggplot2::element_text(face = "bold", size = 12),
      axis.title = ggplot2::element_text(face = "bold"),
      plot.title = ggplot2::element_text(face = "bold", size = 12),
      panel.grid.major = ggplot2::element_line(color = "lightgrey", linewidth = 0.01),
      panel.grid.minor = ggplot2::element_line(color = "lightgrey", linewidth = 0.01),
      panel.border = ggplot2::element_rect(color = "black", linewidth = 0.01),
      legend.position = ifelse(show_legend, "right", "none"))
  
  ggplot2::ggsave(filename = out_file, plot = p, width = width, height = height,
    units = "in", dpi = 600, compression = "lzw" )
  p}




