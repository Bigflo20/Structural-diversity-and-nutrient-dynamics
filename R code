##### Helper function to bootstrap path-specific effects for one feedback pSEM
bootstrap_feedback_psem_path_specific_one_model <- function(data,
                                                            nutrient_var, index_var, clay,
                                                            cwm, family, depth_label,
                                                            focal_sources = NULL,
                                                            n_boot = 1000, seed = 123,
                                                            use_only_significant = FALSE,
                                                            p_cutoff = 0.05, max_depth = 6) {
  
  if (is.null(focal_sources)) {focal_sources <- c(nutrient_var, "agb", "ai", "hmod",
      clay, cwm, "fdis", "sesmpd")}
  
  focal_sources <- unique(focal_sources)
  
  set.seed(seed)
  
  # Fit original feedback pSEM
  original_sem <- build_feedback_psem( data = data, nutrient_var = nutrient_var, index_var = index_var, clay = clay, cwm = cwm)
  
  # Extract path-specific effects from original model
  original_paths <- path_specific_effects_from_psem(
    sem_model = original_sem, target = index_var, focal_sources = focal_sources,
    use_only_significant = use_only_significant, p_cutoff = p_cutoff, max_depth = max_depth)
  
  if (nrow(original_paths) == 0) {warning("No feedback paths found in original model for: ", nutrient_var, " -> ", index_var)
    return(NULL)
    }
  
  path_names <- original_paths$path
  
  original_vector <- vectorize_path_effects_for_boot(path_tbl = original_paths, path_names = path_names)
  
  boot_mat <- matrix(NA_real_, nrow = n_boot,  ncol = length(original_vector) )
  
  colnames(boot_mat) <- names(original_vector)
  
  boot_status <- data.frame(iteration = seq_len(n_boot), success = FALSE, error = NA_character_ )
  
  # Bootstrap loop
  for (b in seq_len(n_boot)) {
      boot_dat <- make_cluster_boot_data(data = data,       cluster_var = "plot_ID")
    
    res <- tryCatch({
      boot_sem <- build_feedback_psem(data = boot_dat, nutrient_var = nutrient_var, index_var = index_var, clay = clay, cwm = cwm )
      boot_paths <- path_specific_effects_from_psem(sem_model = boot_sem, target = index_var, focal_sources = focal_sources,
        use_only_significant = use_only_significant, p_cutoff = p_cutoff, max_depth = max_depth)
      vectorize_path_effects_for_boot(path_tbl = boot_paths, path_names = path_names)}, error = function(e) e)
    
    if (inherits(res, "error")) {boot_status$success[b] <- FALSE
      boot_status$error[b] <- conditionMessage(res)
    } else {
      boot_mat[b, ] <- res
      boot_status$success[b] <- TRUE}}
  
  boot_summary <- summarise_boot_path_effects(original_paths = original_paths, boot_matrix = boot_mat, conf = 0.95) |>
    dplyr::mutate(family = family, depth_label = depth_label, nutrient_var = nutrient_var, index = index_var,
      response = index_var, clay = clay, cwm = cwm, n_boot_requested = n_boot,
      n_model_successful = sum(boot_status$success))
  
  list(original_sem = original_sem, original_paths = original_paths, bootstrap_summary = boot_summary,
    bootstrap_replicates = as.data.frame(boot_mat), bootstrap_status = boot_status)}



