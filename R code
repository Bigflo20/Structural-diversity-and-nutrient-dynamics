# Helper function for getting pSEM coefficients
get_coefs <- function(sem_model) {
  cf <- piecewiseSEM::coefs(sem_model, standardize = "scale") |> as.data.frame()
  estimate_col <- if ("Std.Estimate" %in% names(cf)) "Std.Estimate" else "Estimate"
  p_col <- if ("P.Value" %in% names(cf)) "P.Value" else if ("P" %in% names(cf)) "P" else NA_character_

  out <- data.frame(
    response  = as.character(cf[["Response"]]),
    predictor = as.character(cf[["Predictor"]]),
    estimate  = as.numeric(cf[[estimate_col]]),
    p_value   = if (!is.na(p_col)) as.numeric(cf[[p_col]]) else NA_real_,
    stringsAsFactors = FALSE
  )
  out}

# Helper function to get all paths
all_paths_to_target <- function(edges, target, max_depth = 6) {
  paths <- list()
  starts <- setdiff(unique(edges$from), target)

  extend_path <- function(current_path, current_node) {
    if (length(current_path) > max_depth) return(NULL)
    next_edges <- edges |> filter(from == current_node)
    if (nrow(next_edges) == 0) return(NULL)

    for (i in seq_len(nrow(next_edges))) {
      nxt <- next_edges$to[i]
      # avoid cycles
      if (nxt %in% current_path) next
      new_path <- c(current_path, nxt)
      if (nxt == target) {
        paths[[length(paths) + 1]] <<- new_path
      } else {
        extend_path(new_path, nxt)}}}
  for (s in starts) extend_path(s, s)
  paths}


# Helper function for calculating relative contribution
relative_contribution_from_psem <- function(sem_model, target, p_cutoff = 0.05,
                                            use_only_significant = TRUE) {
  cf <- get_coefs(sem_model)
  cf <- cf |>
    filter(!predictor %in% c("(Intercept)", "~~"), !is.na(estimate))
  if (use_only_significant) {
    cf <- cf |> filter(!is.na(p_value), p_value < p_cutoff)}

  edges <- cf |>
    transmute(from = predictor, to = response, beta = estimate)
  paths <- all_paths_to_target(edges, target = target)
  if (length(paths) == 0) {
    return(list(paths = data.frame(), total_effects = data.frame()))}

  path_tbl <- purrr::map_dfr(paths, function(p) {
    betas <- purrr::map2_dbl(p[-length(p)], p[-1], function(a, b) {
      edges |> filter(from == a, to == b) |> slice(1) |> pull(beta)})
    data.frame(
      source = p[1],
      target = target,
      path = paste(p, collapse = " -> "),
      n_edges = length(betas),
      path_effect = prod(betas),
      stringsAsFactors = FALSE) })

  total_effects <- path_tbl |>
    group_by(source) |>
    summarise(total_effect = sum(path_effect, na.rm = TRUE), .groups = "drop") |>
    mutate(relative_contribution = abs(total_effect) / sum(abs(total_effect), na.rm = TRUE) * 100) |>
    arrange(desc(relative_contribution))
  list(paths = path_tbl, total_effects = total_effects)
}


# Helper function to label predictor variables
label_predictor_group <- function(x, index_label = "VCI") {
  dplyr::case_when(
    x %in% c("vci_sum", "vci_pca", "vci_pca_weighted", "vci_group_balanced",
             "rich_mm", "cvdbh_mm", "cvheight_mm", "dens_mm") ~ index_label,
    x == "agb" ~ "AGB",
    x == "fdis" ~ "FDIS",
    x == "sesmpd" ~ "sesMPD",
