############# Helper function for min-max transformation
minmax <- function(x) {
  rng <- range(x, na.rm = TRUE)
  if (diff(rng) == 0) return(rep(0, length(x)))
  (x - rng[1]) / diff(rng)
}

############# Helper function for scaling
safe_scale <- function(x) as.numeric(scale(x, center = TRUE, scale = TRUE))

############# Helper function for aligning PC1
# Note: PCA axes are arbitrary in sign. Align PC1 so larger values mean greater
# complexity relative to the submitted sum index.

align_pc_sign <- function(pc, reference) {
  if (cor(pc, reference, use = "pairwise.complete.obs") < 0) -pc else pc}


############# Main VCI used for the analysis (equal weight sum of all 4 metrics)
data_flo <- data_flo |>
  mutate(
    rich_mm     = minmax(rich),
    cvdbh_mm    = minmax(cvdbh),
    cvheight_mm = minmax(cvheight),
    dens_mm     = minmax(dens),

    vci_sum_raw = rich_mm + cvdbh_mm + cvheight_mm + dens_mm,
    vci_sum     = safe_scale(vci_sum_raw),

############# Group-balanced VCI (VCI_GR)
# Note: species receives 50%; structural composition metrics receives 50%, 
# calculated as the mean of DBH CV, height CV and density.
    vci_group_balanced_raw = 0.5 * rich_mm + 0.5 * ((cvdbh_mm + cvheight_mm + dens_mm) / 3),
    vci_group_balanced     = safe_scale(vci_group_balanced_raw) )


############# PCA-based VCI (VCI_PCA)
pca_vci <- prcomp(data_flo[, c("rich_mm", "cvdbh_mm", "cvheight_mm", "dens_mm")],
                  center = TRUE, scale. = TRUE)
data_flo$vci_pca <- safe_scale(align_pc_sign(pca_vci$x[, 1], data_flo$vci_sum))
#data_flo$vci_pca_raw <-align_pc_sign(pca_vci$x[, 1], data_flo$vci_sum)


############# PCA-weighted additive VCI (PCA_WPCA)
# Note: this Uses absolute PC1 loadings as objective weights. This remains additive
# but avoids arbitrary equal weighting. Weights are normalized to sum to one.
w_vci <- abs(pca_vci$rotation[, 1])
w_vci <- w_vci / sum(w_vci)

data_flo <- data_flo |>
  mutate(
    vci_pca_weighted_raw = w_vci["rich_mm"] * rich_mm +
                           w_vci["cvdbh_mm"] * cvdbh_mm +
                           w_vci["cvheight_mm"] * cvheight_mm +
                           w_vci["dens_mm"] * dens_mm,
    vci_pca_weighted = safe_scale(vci_pca_weighted_raw) )

############# Diagnostics for alternative indices
write.csv(as.data.frame(pca_vci$rotation[, 1, drop = FALSE]),
          "diagnostic_PCA_loadings_VCI.csv")
write.csv(data.frame(component = names(w_vci), weight = as.numeric(w_vci)),
          "diagnostic_PCA_weights_VCI.csv", row.names = FALSE)

############# Organizing all VCIs and checking correlations among them
index_vars <- c("vci_sum", "vci_pca", "vci_pca_weighted", "vci_group_balanced")

index_cor <- data_flo |>
  select(any_of(index_vars)) |>
  cor(use = "pairwise.complete.obs")
