### Helper function for lme
fixed_formula_lm <- function(model) {lm(formula(model), data = model$data)}

### Helper function for computing Variance Inflation Factor (VIF)
safe_vif_lme <- function(model) {out <- tryCatch({
    v <- car::vif(fixed_formula_lm(model))
    if (is.matrix(v)) v <- v[, "GVIF^(1/(2*Df))"]
    data.frame(term = names(v), VIF = as.numeric(v), row.names = NULL)
  }, error = function(e) {
    data.frame(term = NA_character_, VIF = NA_real_)})
  out}

### Helper function for model diagnostic
diagnose_lme <- function(model, model_name) {
  res <- residuals(model, type = "normalized")
  shapiro_p <- if (length(res) >= 3 && length(res) <= 5000) shapiro.test(res)$p.value else NA_real_
  vif_tbl <- safe_vif_lme(model)
  infl <- data.frame(model = model_name, fitted = fitted(model), residual = res,
    abs_std_resid = abs(as.numeric(scale(res)))) |>
    filter(abs_std_resid > 3)
  list(
    model_name = model_name,
    shapiro_residual_p = shapiro_p,
    vif = vif_tbl,
    residual_outliers = infl)}

### Helper function for selecting with VIF <= 5
vif_ok_lme <- function(model, threshold = 5) {
  v <- safe_vif_lme(model)
  if (all(is.na(v$VIF))) return(FALSE)
  all(v$VIF < threshold, na.rm = TRUE)}





