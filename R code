# Helper function for fitting lme
fit_lme <- function(formula_text, data) {
  fixed_formula <- stats::as.formula(formula_text)
  model <- nlme::lme(
    fixed = fixed_formula,
    random = ~ 1 | vegetation / plot_ID,
    data = data,
    method = "ML",
    na.action = na.fail,
    control = nlme::lmeControl(opt = "optim"))
  model$call$fixed <- fixed_formula
  model}


# Helper function for building main pSEM
build_main_psem <- function(data, index_var, response, clay, cwm) {
  psem(
    fit_lme(paste(index_var, "~ ai + hmod +", clay), data),
    fit_lme(paste("fdis ~ ai + hmod +", clay, "+", index_var), data),
    fit_lme(paste(cwm, "~ ai + hmod +", clay, "+", index_var), data),
    fit_lme(paste("sesmpd ~ ai + hmod +", clay, "+", index_var), data),
    fit_lme(paste("agb ~ ai + hmod +", clay, "+", index_var, "+", cwm, "+ fdis + sesmpd"), data),
    fit_lme(paste(response, "~ ai + hmod +", clay, "+", index_var, "+", cwm, "+ fdis + sesmpd + agb"), data))}


