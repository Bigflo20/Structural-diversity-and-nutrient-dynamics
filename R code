#####  Helper function for Safe bivariate model fitting

fit_bivariate_lme_safe <- function(response, predictor, data) {
  formula_text <- paste(response, "~", predictor)
  tryCatch(fit_lme(formula_text, data), error = function(e) e)}


#####  Helper function for extracting slope, SE, t-value, and p-value
extract_bivariate_slope <- function(response, predictor, family, depth_label,
                                    clay, cwm, data) {
    model <- fit_bivariate_lme_safe(response = response, predictor = predictor, data = data)
  
  if (inherits(model, "error")) {
    return(data.frame(
      family = family,
      depth_label = depth_label,
      response = response,
      predictor = predictor,
      clay = clay,
      cwm = cwm,
      slope = NA_real_,
      SE = NA_real_,
      DF = NA_real_,
      t_value = NA_real_,
      p_value = NA_real_,
      n_obs = NA_integer_,
      model_failed = TRUE,
      error_message = conditionMessage(model),
      stringsAsFactors = FALSE))  }
  
  sm <- summary(model)
  
  data.frame(
    family = family,
    depth_label = depth_label,
    response = response,
    predictor = predictor,
    clay = clay,
    cwm = cwm,
    slope = sm$tTable[2, "Value"],
    SE = sm$tTable[2, "Std.Error"],
    DF = sm$tTable[2, "DF"],
    t_value = sm$tTable[2, "t-value"],
    p_value = sm$tTable[2, "p-value"],
    n_obs = nobs(model),
    model_failed = FALSE,
    error_message = NA_character_,
    stringsAsFactors = FALSE)
}



#####  Helper function for labelling predictor 
label_bivariate_predictor <- function(x) {
  dplyr::case_when(
    x == "agb" ~ "AGB",
    x == "sesmpd" ~ "sesMPD",
    x %in% c("hm", "lnc", "wd", "lcc", "sla", "ldmc") ~ "CWM",
    x == "fdis" ~ "FDIS",
    
    x == "vci_sum" ~ "VCI",
    x == "vci_pca" ~ "VCI_PCA",
    x == "vci_pca_weighted" ~ "VCI_WPCA",
    x == "vci_group_balanced" ~ "VCI_GR",
    
    stringr::str_detect(x, "^clay") ~ "Clay",
    x == "ai" ~ "AI",
    x == "hmod" ~ "HMOD",
    TRUE ~ x)
}


